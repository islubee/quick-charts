{
  "name": "quick-charts",
  "version": "1.1.0",
  "description": "Simple charts for react",
  "main": "dist/index.js",
  "module": "dist/index.es.js",
  "scripts": {
    "test": "jest",
    "storybook": "start-storybook -p 6006",
    "build-storybook": "build-storybook",
    "build-lib": "rollup -c"
  },
  "jest": {
    "testEnvironment": "jsdom",
    "setupFilesAfterEnv": ["<rootDir>/src/setupTests.js"],
    "moduleNameMapper": {
      "\\.(css|less|scss|sass)$": "<rootDir>/src/__mocks__/styleMock.js"
    },
    "transformIgnorePatterns": [
      "/node_modules/(?!(d3|d3-array|d3-scale|d3-shape|d3-axis|d3-selection|d3-interpolate|d3-color|d3-format|d3-time|d3-time-format|d3-path|d3-brush|d3-chord|d3-contour|d3-delaunay|d3-dispatch|d3-drag|d3-dsv|d3-ease|d3-fetch|d3-force|d3-geo|d3-hierarchy|d3-quadtree|d3-random|d3-sankey|d3-scale-chromatic|d3-timer|d3-transition|d3-voronoi|d3-zoom|internmap|robust-predicates|delaunator)/)"
    ]
  },
  "author": "Mohammed Islubee",
  "license": "MIT",
  "devDependencies": {
    "@babel/core": "^7.17.9",
    "@babel/preset-env": "^7.29.2",
    "@babel/preset-react": "^7.16.7",
    "@rollup/plugin-commonjs": "^21.0.3",
    "@rollup/plugin-node-resolve": "^13.2.0",
    "@storybook/addon-actions": "^6.4.21",
    "@storybook/addon-essentials": "^6.4.21",
    "@storybook/addon-interactions": "^6.4.21",
    "@storybook/addon-links": "^6.4.21",
    "@storybook/react": "^6.4.21",
    "@storybook/testing-library": "^0.0.9",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "babel-jest": "^30.3.0",
    "babel-loader": "^8.2.4",
    "d3": "^5.16.0",
    "identity-obj-proxy": "^3.0.0",
    "jest": "^30.3.0",
    "jest-environment-jsdom": "^30.3.0",
    "prop-types": "^15.7.2",
    "react": "^18.0.0",
    "react-dom": "^18.0.0",
    "react-quickstore": "^2.0.1",
    "react-scripts": "^5.0.0",
    "resize-observer-polyfill": "^1.5.1",
    "rollup": "^2.70.1",
    "rollup-plugin-babel": "^4.4.0",
    "rollup-plugin-commonjs": "^10.1.0",
    "rollup-plugin-peer-deps-external": "^2.2.4",
    "rollup-plugin-postcss": "^4.0.2",
    "rollup-plugin-terser": "^7.0.2"
  },
  "peerDependencies": {
    "react": "^18.0.0",
    "react-dom": "^18.0.0"
  },
  "browser": {
    "[module-name]": false
  }
}
